{
  "name": "@boltdocs/cli",
  "version": "1.0.0",
  "description": "CLI for Boltdocs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "boltdocs": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "docs",
    "documentation",
    "static site generator",
    "ssg",
    "markdown",
    "mdx",
    "react",
    "vite",
    "typescript"
  ],
  "author": "Jesus Alcala",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cac": "^7.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
