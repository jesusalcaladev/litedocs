{
  "name": "@litedocs/plugin-mermaid",
  "version": "1.0.0",
  "description": "Mermaid diagram plugin for Litedocs",
  "main": "dist/node/index.js",
  "module": "dist/node/index.mjs",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.mjs",
      "require": "./dist/node/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    },
    "./style.css": "./dist/client/index.css"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "mermaid": "^11.12.3",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/react": "^18.3.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
