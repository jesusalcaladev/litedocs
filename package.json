{
  "name": "litedocs-monorepo",
  "private": true,
  "scripts": {
    "preinstall": "pnpm -C packages/core build",
    "dev": "pnpm -C example dev",
    "build:core": "pnpm --filter litedocs build",
    "build:cli": "pnpm --filter create-litedocs build",
    "build": "turbo run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "turbo": "^1.13.0"
  }
}
