{
  "name": "boltdocs-monorepo",
  "private": true,
  "scripts": {
    "preinstall": "pnpm -C packages/core build",
    "dev": "pnpm -C docs dev",
    "build:core": "pnpm --filter boltdocs build",
    "build:cli": "pnpm --filter create-boltdocs build",
    "build": "turbo run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prerelease": "pnpm build && changeset publish"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "turbo": "latest"
  }
}
