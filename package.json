{
  "name": "boltdocs-monorepo",
  "private": true,
  "scripts": {
    "preinstall": "pnpm -C packages/core build",
    "dev": "pnpm -C docs dev",
    "build:core": "pnpm --filter boltdocs build",
    "build:cli": "pnpm --filter @boltdocs/cli build",
    "build": "turbo run build",
    "release": "semantic-release",
    "audit": "pnpm audit",
    "benchmark": "node ./benchmarks/run-benchmarks.js",
    "test": "vitest run --dir tests",
    "test:internal": "vitest run --dir internal-testing",
    "test:coverage": "vitest run --dir tests --coverage",
    "lint:md": "markdownlint-cli2 \"**/*.{md,mdx}\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.{md,mdx}\""
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "husky": "^9.0.1",
    "markdownlint-cli2": "^0.21.0",
    "semantic-release": "^25.0.3",
    "turbo": "latest",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "cross-spawn": "^6.0.6",
      "next": "^15.5.10",
      "next-mdx-remote": "^6.0.0",
      "dompurify": "^3.3.2",
      "esbuild": "^0.25.0",
      "svgo": "^4.0.1",
      "flatted": "^3.4.0",
      "undici@^6": "6.24.0",
      "undici@^7": "7.24.0"
    }
  },
  "version": "1.9.0"
}
